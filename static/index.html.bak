<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI SQL Assistant</title>

<!-- ===== 外部依赖(全部从 CDN 加载,无需 npm) ===== -->
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11/styles/github.min.css">
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11/lib/core.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11/lib/languages/sql.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/highlight.js@11/lib/languages/python.min.js"></script>

<style>
  /* 自定义滚动条,更好看 */
  .scrollbar-thin::-webkit-scrollbar { width: 6px; }
  .scrollbar-thin::-webkit-scrollbar-track { background: transparent; }
  .scrollbar-thin::-webkit-scrollbar-thumb { background: #d4d4d8; border-radius: 3px; }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover { background: #a1a1aa; }

  /* Markdown 渲染样式 */
  .md-content h1, .md-content h2, .md-content h3 {
    font-weight: 600; margin-top: 0.75em; margin-bottom: 0.5em;
  }
  .md-content h1 { font-size: 1.25em; }
  .md-content h2 { font-size: 1.15em; }
  .md-content h3 { font-size: 1.05em; }
  .md-content p { margin-bottom: 0.5em; line-height: 1.65; }
  .md-content ul, .md-content ol { margin-left: 1.5em; margin-bottom: 0.5em; }
  .md-content li { margin-bottom: 0.2em; }
  .md-content code {
    background: #f4f4f5; padding: 1px 5px; border-radius: 3px;
    font-size: 0.9em; color: #db2777;
  }
  .md-content pre {
    background: #f4f4f5; border-radius: 6px; padding: 12px;
    overflow-x: auto; margin: 8px 0; position: relative;
  }
  .md-content pre code {
    background: transparent; padding: 0; color: inherit;
    font-size: 0.88em; line-height: 1.5;
  }
  .md-content strong { font-weight: 600; }
  .md-content a { color: #2563eb; text-decoration: underline; }

  /* 代码块复制按钮 */
  .copy-btn {
    position: absolute; top: 6px; right: 6px;
    background: #e4e4e7; border: none; padding: 3px 8px;
    border-radius: 4px; font-size: 11px; cursor: pointer;
    color: #52525b;
  }
  .copy-btn:hover { background: #d4d4d8; }
  .copy-btn.copied { background: #86efac; color: #166534; }

  /* 打字机光标 */
  .typing-cursor::after {
    content: '▋'; animation: blink 1s infinite; color: #6366f1;
  }
  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
</style>
</head>

<body class="bg-gray-50 h-screen flex flex-col overflow-hidden">

<!-- ==================== 顶部栏 ==================== -->
<header class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between">
  <div class="flex items-center gap-4">
    <h1 class="text-lg font-semibold text-gray-800">🤖 AI SQL Assistant</h1>
    <span id="provider-badge" class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded">loading...</span>
  </div>

  <!-- 模式切换 Tab -->
  <div class="flex gap-1" id="mode-tabs">
    <button data-mode="chat" class="mode-tab px-3 py-1.5 text-sm rounded bg-blue-600 text-white">对话</button>
    <button data-mode="explain" class="mode-tab px-3 py-1.5 text-sm rounded text-gray-600 hover:bg-gray-100">SQL 解释</button>
    <button data-mode="optimize" class="mode-tab px-3 py-1.5 text-sm rounded text-gray-600 hover:bg-gray-100">SQL 优化</button>
    <button data-mode="nl2sql" class="mode-tab px-3 py-1.5 text-sm rounded text-gray-600 hover:bg-gray-100">NL→SQL</button>
  </div>
</header>

<!-- ==================== 主体:左侧栏 + 聊天区 ==================== -->
<div class="flex flex-1 overflow-hidden">

  <!-- ===== 左侧会话栏 ===== -->
  <aside class="w-64 bg-white border-r border-gray-200 flex flex-col">
    <div class="p-3 border-b border-gray-200">
      <button id="new-chat-btn" class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm py-2 rounded-md transition-colors">
        + 新对话
      </button>
    </div>
    <div id="session-list" class="flex-1 overflow-y-auto scrollbar-thin p-2">
      <!-- 会话列表 JS 动态渲染 -->
    </div>
    <div class="p-3 border-t border-gray-200 text-xs text-gray-400">
      <div>历史仅在内存中</div>
      <div>重启后会丢失</div>
    </div>
  </aside>

  <!-- ===== 聊天主区 ===== -->
  <main class="flex-1 flex flex-col bg-gray-50">

    <!-- 消息列表 -->
    <div id="messages" class="flex-1 overflow-y-auto scrollbar-thin p-6 space-y-4">
      <div class="text-center text-gray-400 text-sm mt-20">
        <div class="text-3xl mb-2">💬</div>
        <div>和 AI 开始对话吧</div>
        <div class="mt-1 text-xs">选择顶部的模式,输入问题或 SQL</div>
      </div>
    </div>

    <!-- 输入区 -->
    <div class="border-t border-gray-200 bg-white p-4">
      <div class="max-w-3xl mx-auto">
        <div id="input-hint" class="text-xs text-gray-500 mb-2">💡 对话模式 - 可以问任何数据工程相关问题</div>
        <div class="flex gap-2">
          <textarea id="input-box"
            rows="3"
            placeholder="输入消息... (Enter 发送,Shift+Enter 换行)"
            class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm resize-none focus:outline-none focus:border-blue-500 scrollbar-thin"></textarea>
          <button id="send-btn"
            class="bg-blue-600 hover:bg-blue-700 disabled:bg-gray-300 text-white px-5 rounded-lg transition-colors font-medium">
            发送
          </button>
        </div>
      </div>
    </div>

  </main>
</div>

<!-- ==================== JavaScript ==================== -->
<script>
// ========== 全局状态 ==========
const API_BASE = '';  // 同源,留空即可
let currentSessionId = null;
let currentMode = 'chat';
let isStreaming = false;

// ========== 初始化 marked + highlight.js ==========
hljs.registerLanguage('sql', hljs.getLanguage('sql') || (() => {}));
hljs.registerLanguage('python', hljs.getLanguage('python') || (() => {}));

marked.setOptions({
  highlight: function(code, lang) {
    if (lang && hljs.getLanguage(lang)) {
      return hljs.highlight(code, { language: lang }).value;
    }
    return hljs.highlightAuto(code).value;
  },
  breaks: true,
});

// ========== 工具函数 ==========
function $(sel) { return document.querySelector(sel); }

function scrollToBottom() {
  const el = $('#messages');
  el.scrollTop = el.scrollHeight;
}

function renderMarkdown(text) {
  const html = marked.parse(text);
  // 给每个 pre 添加复制按钮
  return html.replace(/<pre><code/g, '<pre><button class="copy-btn" onclick="copyCode(this)">复制</button><code');
}

function copyCode(btn) {
  const code = btn.nextElementSibling.textContent;
  navigator.clipboard.writeText(code).then(() => {
    btn.textContent = '已复制 ✓';
    btn.classList.add('copied');
    setTimeout(() => {
      btn.textContent = '复制';
      btn.classList.remove('copied');
    }, 1500);
  });
}

// ========== 消息气泡渲染 ==========
function addMessage(role, content) {
  // 如果是第一条消息,清空欢迎页
  const msgList = $('#messages');
  if (msgList.querySelector('.text-center.text-gray-400')) {
    msgList.innerHTML = '';
  }

  const wrapper = document.createElement('div');
  wrapper.className = role === 'user' ? 'flex justify-end' : 'flex justify-start';

  const bubble = document.createElement('div');
  bubble.className = role === 'user'
    ? 'bg-blue-600 text-white max-w-2xl rounded-lg px-4 py-3 whitespace-pre-wrap'
    : 'bg-white border border-gray-200 max-w-2xl rounded-lg px-4 py-3 md-content';

  if (role === 'user') {
    bubble.textContent = content;
  } else {
    bubble.innerHTML = renderMarkdown(content);
  }

  wrapper.appendChild(bubble);
  msgList.appendChild(wrapper);
  scrollToBottom();
  return bubble;  // 返回气泡,流式时继续往里追加
}

// ========== 发送消息(核心) ==========
async function sendMessage() {
  if (isStreaming) return;
  const input = $('#input-box');
  const text = input.value.trim();
  if (!text) return;

  isStreaming = true;
  input.value = '';
  $('#send-btn').disabled = true;
  $('#send-btn').textContent = '发送中';

  // 显示用户消息
  addMessage('user', text);

  // 创建 AI 消息气泡(空的,准备接收流式内容)
  const aiBubble = addMessage('assistant', '');
  aiBubble.classList.add('typing-cursor');

  // 根据模式决定调用哪个端点
  let endpoint, body;
  if (currentMode === 'chat') {
    endpoint = '/api/ai/chat/stream';
    body = { message: text, session_id: currentSessionId };
  } else if (currentMode === 'explain') {
    endpoint = '/api/ai/explain/stream';
    body = { sql: text };
  } else if (currentMode === 'optimize') {
    endpoint = '/api/ai/optimize/stream';
    body = { sql: text };
  } else if (currentMode === 'nl2sql') {
    endpoint = '/api/ai/nl2sql/stream';
    body = { question: text };
  }

  try {
    const resp = await fetch(API_BASE + endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });

    if (!resp.ok) throw new Error('HTTP ' + resp.status);

    // ===== 核心:读取 SSE 流 =====
    const reader = resp.body.getReader();
    const decoder = new TextDecoder();
    let fullReply = '';
    let buffer = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;

      buffer += decoder.decode(value, { stream: true });
      // SSE 消息以 \n\n 分隔
      const lines = buffer.split('\n\n');
      buffer = lines.pop();  // 最后一个可能不完整,留到下次

      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        const data = line.slice(6);  // 去掉 "data: "
        if (data === '[DONE]') continue;
        if (data.startsWith('[ERROR]')) {
          fullReply += '\n\n❌ ' + data;
          continue;
        }
        fullReply += data;
        aiBubble.innerHTML = renderMarkdown(fullReply);
        scrollToBottom();
      }
    }

    // 流结束,去掉光标
    aiBubble.classList.remove('typing-cursor');

    // 对话模式:如果是新会话,刷新会话列表并记录 id
    if (currentMode === 'chat') {
      await refreshSessions();
    }
  } catch (err) {
    aiBubble.innerHTML = '<span style="color:red">请求失败: ' + err.message + '</span>';
    aiBubble.classList.remove('typing-cursor');
  } finally {
    isStreaming = false;
    $('#send-btn').disabled = false;
    $('#send-btn').textContent = '发送';
    input.focus();
  }
}

// ========== 会话管理 ==========
async function refreshSessions() {
  try {
    const resp = await fetch(API_BASE + '/api/ai/sessions');
    const sessions = await resp.json();
    renderSessionList(sessions);
  } catch (err) {
    console.error('刷新会话失败', err);
  }
}

function renderSessionList(sessions) {
  const list = $('#session-list');
  if (sessions.length === 0) {
    list.innerHTML = '<div class="text-xs text-gray-400 text-center py-4">暂无历史会话</div>';
    return;
  }
  list.innerHTML = sessions.map(s => `
    <div class="session-item group flex items-start justify-between p-2 mb-1 rounded cursor-pointer hover:bg-gray-100 ${s.session_id === currentSessionId ? 'bg-blue-50' : ''}"
         data-id="${s.session_id}">
      <div class="flex-1 min-w-0">
        <div class="text-sm text-gray-800 truncate">${s.preview}</div>
        <div class="text-xs text-gray-400 mt-0.5">${s.message_count} 条消息</div>
      </div>
      <button class="delete-btn opacity-0 group-hover:opacity-100 text-xs text-red-500 hover:text-red-700 ml-2" data-id="${s.session_id}">×</button>
    </div>
  `).join('');

  // 绑定点击加载
  list.querySelectorAll('.session-item').forEach(el => {
    el.addEventListener('click', (e) => {
      if (e.target.classList.contains('delete-btn')) return;
      loadSession(el.dataset.id);
    });
  });
  // 绑定删除
  list.querySelectorAll('.delete-btn').forEach(el => {
    el.addEventListener('click', async (e) => {
      e.stopPropagation();
      await deleteSession(el.dataset.id);
    });
  });
}

async function loadSession(sessionId) {
  currentSessionId = sessionId;
  try {
    const resp = await fetch(API_BASE + '/api/ai/sessions/' + sessionId);
    const detail = await resp.json();

    // 重建消息列表
    const msgList = $('#messages');
    msgList.innerHTML = '';
    for (const msg of detail.messages) {
      addMessage(msg.role === 'user' ? 'user' : 'assistant', msg.content);
    }
    // 高亮选中
    document.querySelectorAll('.session-item').forEach(el => {
      el.classList.toggle('bg-blue-50', el.dataset.id === sessionId);
    });
    // 切到对话模式
    switchMode('chat');
  } catch (err) {
    console.error('加载会话失败', err);
  }
}

async function deleteSession(sessionId) {
  if (!confirm('确定删除这个会话吗?')) return;
  try {
    await fetch(API_BASE + '/api/ai/sessions/' + sessionId, { method: 'DELETE' });
    if (sessionId === currentSessionId) {
      currentSessionId = null;
      $('#messages').innerHTML = '<div class="text-center text-gray-400 text-sm mt-20"><div class="text-3xl mb-2">💬</div><div>选个会话或新建对话</div></div>';
    }
    await refreshSessions();
  } catch (err) {
    console.error('删除会话失败', err);
  }
}

async function newChat() {
  try {
    const resp = await fetch(API_BASE + '/api/ai/sessions', { method: 'POST' });
    const data = await resp.json();
    currentSessionId = data.session_id;
    $('#messages').innerHTML = '<div class="text-center text-gray-400 text-sm mt-20"><div class="text-3xl mb-2">💬</div><div>新对话已创建</div><div class="text-xs mt-1">开始提问吧</div></div>';
    switchMode('chat');
    await refreshSessions();
  } catch (err) {
    console.error('创建会话失败', err);
  }
}

// ========== 模式切换 ==========
const MODE_HINTS = {
  chat: '💬 对话模式 - 可以问任何数据工程相关问题,支持多轮对话',
  explain: '📖 SQL 解释模式 - 粘贴一段 SQL,获得详细解读',
  optimize: '⚡ SQL 优化模式 - 粘贴 SQL,获得性能优化建议',
  nl2sql: '✨ NL→SQL 模式 - 用自然语言描述需求,生成 SQL',
};

function switchMode(mode) {
  currentMode = mode;
  document.querySelectorAll('.mode-tab').forEach(btn => {
    const active = btn.dataset.mode === mode;
    btn.className = 'mode-tab px-3 py-1.5 text-sm rounded ' +
      (active ? 'bg-blue-600 text-white' : 'text-gray-600 hover:bg-gray-100');
  });
  $('#input-hint').textContent = MODE_HINTS[mode];

  // 非对话模式不使用 session
  if (mode !== 'chat') {
    $('#messages').innerHTML = `<div class="text-center text-gray-400 text-sm mt-20"><div class="text-3xl mb-2">✨</div><div>${MODE_HINTS[mode]}</div></div>`;
  }
}

// ========== 初始化 ==========
async function init() {
  // 绑定事件
  $('#send-btn').addEventListener('click', sendMessage);
  $('#input-box').addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });
  $('#new-chat-btn').addEventListener('click', newChat);
  document.querySelectorAll('.mode-tab').forEach(btn => {
    btn.addEventListener('click', () => switchMode(btn.dataset.mode));
  });

  // 加载服务状态
  try {
    const resp = await fetch(API_BASE + '/api/ai/status');
    const status = await resp.json();
    $('#provider-badge').textContent = `${status.provider} · ${status.model}`;
  } catch (e) {
    $('#provider-badge').textContent = '服务未连接';
  }

  // 加载会话列表
  await refreshSessions();
}

init();
</script>
</body>
</html>
